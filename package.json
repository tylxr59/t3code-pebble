{
  "name": "t3code-pebble",
  "version": "0.1.1",
  "author": "T3 Code Pebble Contributors",
  "private": true,
  "scripts": {
    "check:js": "node --check src/pkjs/index.js",
    "lint:js": "eslint src/pkjs/**/*.js",
    "format:c:check": "clang-format --dry-run --Werror src/c/*.c src/c/*.h",
    "lint": "npm run check:js && npm run lint:js && npm run format:c:check",
    "build": "pebble build"
  },
  "pebble": {
    "displayName": "T3 Code",
    "uuid": "ebdc99fc-290b-4b29-bcf5-cd50d00bd587",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "capabilities": [
      "configurable"
    ],
    "targetPlatforms": [
      "emery"
    ],
    "watchapp": {
      "watchface": false
    },
    "messageKeys": [
      "Command",
      "Seq",
      "Index",
      "Total",
      "ProjectId",
      "ThreadId",
      "MessageId",
      "Title",
      "Role",
      "Text",
      "Status",
      "Working",
      "UnseenDone",
      "Error"
    ],
    "resources": {
      "media": []
    }
  },
  "devDependencies": {
    "eslint": "^9.39.4"
  }
}
